@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    ViewData["AuthMode"] = "login";
    Layout = "/Views/Shared/_AuthLayout.cshtml";
}

<form id="account" class="auth-form" method="post">
    <div class="auth-head">
        <span class="auth-head-ico"><svg class="hgi"><use href="#i-login"></use></svg></span>
        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Log in to your UniConnect student portal.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="auth-summary text-danger" role="alert"></div>

    <div class="auth-field">
        <span class="auth-field-ico"><svg class="hgi"><use href="#i-mail"></use></svg></span>
        <div class="auth-float">
            <input asp-for="Input.Email" id="Input_Email" class="auth-input" autocomplete="username" placeholder=" " />
            <label asp-for="Input.Email" class="auth-label">Email address</label>
        </div>
    </div>
    <span asp-validation-for="Input.Email" class="auth-error"></span>

    <div class="auth-field">
        <span class="auth-field-ico"><svg class="hgi"><use href="#i-lock"></use></svg></span>
        <div class="auth-float">
            <input asp-for="Input.Password" id="Input_Password" type="password" class="auth-input" autocomplete="current-password" placeholder=" " />
            <label asp-for="Input.Password" class="auth-label">Password</label>
        </div>
        <button type="button" class="auth-pass-toggle" data-pass-toggle="Input_Password" aria-label="Show password" aria-pressed="false">
            <svg class="hgi"><use href="#i-eye"></use></svg>
        </button>
    </div>
    <span asp-validation-for="Input.Password" class="auth-error"></span>

    <div class="auth-options">
        <label class="auth-check" asp-for="Input.RememberMe">
            <input class="form-check-input" asp-for="Input.RememberMe" />
            @Html.DisplayNameFor(m => m.Input.RememberMe)
        </label>
        <a class="auth-link" asp-page="./ForgotPassword">Forgot password?</a>
    </div>

    <button id="login-submit" type="submit" class="auth-submit">
        <span>Log in</span>
        <svg class="hgi"><use href="#i-arrow-right"></use></svg>
    </button>

    <div class="auth-mini-links">
        <a asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
    </div>

    <div class="auth-switch">
        New to UniConnect?
        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" data-auth-nav>
            Create an account <svg class="hgi"><use href="#i-arrow-right"></use></svg>
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
