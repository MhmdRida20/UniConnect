{
  "ConnectionStrings": {
    // LocalDB is installed with Visual Studio by default — no separate SQL Server install needed.
    // The database file will live in your user folder; LocalDB auto-creates it on first migration.
    //
    // Other options:
    //   - SQL Server Express:   "Server=.\\SQLEXPRESS;Database=UniConnectDb;Trusted_Connection=True;TrustServerCertificate=True"
    //   - Full SQL Server:      "Server=YOUR_SERVER;Database=UniConnectDb;User Id=sa;Password=YourPwd;TrustServerCertificate=True"
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=UniConnectDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
