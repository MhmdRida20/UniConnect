@model UniConnect.Models.Ride
@{
    ViewData["Title"] = "Ride Details";
    var isDriver = (bool)ViewBag.IsDriver;
    var myRequest = ViewBag.MyRequest as UniConnect.Models.RideRequest;

    string StatusPill(UniConnect.Models.RideStatus s) => s switch
    {
        UniConnect.Models.RideStatus.Active => "uc-pill-green",
        UniConnect.Models.RideStatus.Full => "uc-pill-amber",
        UniConnect.Models.RideStatus.Completed => "uc-pill-blue",
        _ => "uc-pill-grey"
    };

    // Build the points the map should plot, server-side, as plain JSON.
    var mapPoints = new List<object>();
    if (Model.DepartureLat.HasValue && Model.DepartureLng.HasValue)
    {
        mapPoints.Add(new
        {
            lat = Model.DepartureLat.Value,
            lng = Model.DepartureLng.Value,
            label = "Departure (meeting point): " + Model.DepartureLocation,
            color = "green"
        });
    }
    if (Model.DestinationLat.HasValue && Model.DestinationLng.HasValue)
    {
        mapPoints.Add(new
        {
            lat = Model.DestinationLat.Value,
            lng = Model.DestinationLng.Value,
            label = "Destination: " + Model.Destination,
            color = "red"
        });
    }
    if (isDriver)
    {
        // Pending requests show as amber pins (so the driver can see where
        // someone wants picking up *before* deciding to accept) — accepted
        // ones show as blue, matching the legend.
        foreach (var req in Model.Requests.Where(r =>
            (r.Status == UniConnect.Models.RideRequestStatus.Pending
             || r.Status == UniConnect.Models.RideRequestStatus.Accepted)
            && r.PickupLat.HasValue && r.PickupLng.HasValue))
        {
            var isPending = req.Status == UniConnect.Models.RideRequestStatus.Pending;
            mapPoints.Add(new
            {
                lat = req.PickupLat!.Value,
                lng = req.PickupLng!.Value,
                label = (isPending ? "Pickup request (pending): " : "Pickup (accepted): ") + (req.Passenger?.FullName ?? "Passenger"),
                color = isPending ? "gold" : "blue"
            });
        }
    }

    // Phase 4 — who's allowed to see/send live location for this ride:
    // the driver (sends) or a passenger with an accepted request (receives).
    var isAcceptedPassenger = myRequest != null && myRequest.Status == UniConnect.Models.RideRequestStatus.Accepted;
    var canTrack = isDriver || isAcceptedPassenger;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/pages/ride-details.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/ride-tracking.css" asp-append-version="true" />
}



<a asp-action="Index" class="form-back"><i class="bi bi-arrow-left"></i> Back to rides</a>

@* ── Header ── *@
<div class="rd-header">
    <div class="rd-route">
        <span class="ride-vehicle"><i class="bi bi-car-front"></i>@Model.Vehicle?.VehicleType</span>
        <h1>
            @Model.DepartureLocation
            <i class="bi bi-arrow-right rd-arrow"></i>
            @Model.Destination
        </h1>
        <p class="rd-subtitle">
            <span><i class="bi bi-person-badge"></i> @Model.Driver?.FullName</span>
            <span><i class="bi bi-calendar-event"></i> @Model.DepartureTime.ToString("dddd, MMM dd · HH:mm")</span>
        </p>
    </div>
    <span class="uc-pill @StatusPill(Model.Status) rd-status">@Model.Status</span>
</div>

@* ── Map ── *@
<div class="rd-map-wrap">
    <div id="rideMap" class="rd-map"></div>
    <div class="rd-map-legend">
        <span><span class="rd-leg rd-leg-green"></span>Departure (meeting point)</span>
        <span><span class="rd-leg rd-leg-red"></span>Destination</span>
        @if (isDriver)
        {
            <span><span class="rd-leg rd-leg-gold"></span>Pending pickup request</span>
            <span><span class="rd-leg rd-leg-blue"></span>Accepted pickup</span>
        }
        @if (canTrack)
        {
            <span><span class="rd-leg rd-leg-orange"></span>Driver's live location (moving)</span>
        }
    </div>
    @if (canTrack)
    {
        <span class="rd-live-badge" id="rideLiveBadge" data-state="off">
            <span class="rd-live-dot"></span> <span id="rideLiveBadgeText">Not tracking</span>
        </span>
    }
</div>
<script type="application/json" id="rideMapData">@Html.Raw(Json.Serialize(mapPoints))</script>

<form id="rideTrackingAntiForgery">@Html.AntiForgeryToken()</form>
<div id="rideTrackingConfig"
     data-ride-id="@Model.Id"
     data-is-driver="@(isDriver ? "true" : "false")"
     data-can-track="@(canTrack ? "true" : "false")"
     data-current-user-id="@ViewBag.CurrentUserId"
     data-trip-started="@(Model.TripStartedAt.HasValue ? "true" : "false")"
     data-ride-status="@Model.Status"
     data-last-lat="@(Model.LastLat?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
     data-last-lng="@(Model.LastLng?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
     data-update-url="@Url.Action("UpdateLocation", "Rides")"
     style="display:none"></div>

<div class="row g-4 mt-1">
    @* ── Ride info + controls ── *@
    <div class="col-lg-6">
        <div class="rd-panel">
            <h2 class="rd-panel-title"><i class="bi bi-info-circle"></i> Ride Info</h2>
            <div class="rd-info-grid">
                <div class="rd-info"><span class="rd-info-lbl">Vehicle</span><span class="rd-info-val">@Model.Vehicle?.VehicleType (@Model.Vehicle?.Color, plate @Model.Vehicle?.PlateNumber)</span></div>
                <div class="rd-info"><span class="rd-info-lbl">Seats available</span><span class="rd-info-val">@Model.AvailableSeats of @Model.TotalSeats</span></div>
                <div class="rd-info"><span class="rd-info-lbl">Departs</span><span class="rd-info-val">@Model.DepartureTime.ToString("MMM dd, HH:mm")</span></div>
                <div class="rd-info"><span class="rd-info-lbl">Status</span><span class="rd-info-val">@Model.Status</span></div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="rd-notes"><i class="bi bi-chat-left-quote"></i> @Model.Notes</div>
            }

            @* ── Driver controls ── *@
            @if (isDriver)
            {
                @if (Model.Status == UniConnect.Models.RideStatus.Active
               || Model.Status == UniConnect.Models.RideStatus.Full)
                {
                    @if (!Model.TripStartedAt.HasValue)
                    {
                        <div class="rd-actions">
                            <form asp-action="StartTrip" asp-route-id="@Model.Id" method="post" class="d-inline" data-loading>
                                @Html.AntiForgeryToken()
                                <button class="btn btn-primary btn-sm"><i class="bi bi-play-circle me-1"></i>Start Trip</button>
                            </form>
                        </div>
                        <p class="rd-pin-hint"><i class="bi bi-info-circle"></i> Starting the trip shares your live location with accepted passengers and stops new requests.</p>
                    }
                    else
                    {
                        <div class="rd-trip-live-note">
                            <i class="bi bi-broadcast"></i> Trip in progress — your location is being shared.
                        </div>
                    }
                    <div class="rd-actions">
                        <form asp-action="CompleteRide" asp-route-id="@Model.Id" method="post" class="d-inline" data-loading>
                            @Html.AntiForgeryToken()
                            <button class="btn btn-success btn-sm"><i class="bi bi-check2-circle me-1"></i>Mark Completed</button>
                        </form>
                        <form asp-action="CancelRide" asp-route-id="@Model.Id" method="post" class="d-inline"
                              data-confirm="Cancel this ride? All passengers will be notified.">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-x-circle me-1"></i>Cancel Ride</button>
                        </form>
                    </div>
                }
            }
            else
            {
                @* ── Passenger controls ── *@
                @if (myRequest == null)
                {
                    @if (Model.Status == UniConnect.Models.RideStatus.Active && Model.AvailableSeats > 0)
                    {
                        <div class="rd-request-box">
                            <h3><i class="bi bi-hand-index-thumb"></i> Request a seat</h3>
                            <form asp-action="RequestRide" asp-route-id="@Model.Id" method="post" data-loading>
                                @Html.AntiForgeryToken()
                                <label class="form-label">Your pickup location</label>
                                <div class="input-icon">
                                    <i class="bi bi-geo-alt"></i>
                                    <input type="text" name="pickupLocation" id="pickupLocationInput" class="form-control" maxlength="150"
                                           required placeholder="Where should the driver pick you up?" />
                                </div>
                                <small class="geo-status" id="pickupGeoStatus"></small>
                                <button type="button" class="ride-my-location-btn" id="useMyLocationPickupBtn">
                                    <i class="bi bi-crosshair"></i> Use my current location
                                </button>
                                <p class="rd-pin-hint"><i class="bi bi-info-circle"></i> Or click the map below to drop your exact pickup pin.</p>
                                <div id="pickupPinMap" class="rd-pickup-map"></div>
                                <input type="hidden" name="pickupLat" id="pickupLatInput" />
                                <input type="hidden" name="pickupLng" id="pickupLngInput" />
                                <button class="btn btn-primary btn-sm mt-3" data-loading-text="Sending…">
                                    <i class="bi bi-send me-1"></i>Send Request
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-3 mb-0">This ride is not accepting requests.</div>
                    }
                }
                else
                {
                    var pillCls = myRequest.Status switch
                    {
                        UniConnect.Models.RideRequestStatus.Accepted => "uc-pill-green",
                        UniConnect.Models.RideRequestStatus.Rejected => "uc-pill-red",
                        UniConnect.Models.RideRequestStatus.Pending => "uc-pill-amber",
                        _ => "uc-pill-grey"
                    };
                    <div class="rd-request-status">
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                            <span class="fw-semibold">Your request</span>
                            <span class="uc-pill @pillCls">@myRequest.Status</span>
                        </div>
                        <p class="mb-2 small text-muted"><i class="bi bi-geo-alt"></i> Pickup: @myRequest.PickupLocation</p>
                        @if (myRequest.Status == UniConnect.Models.RideRequestStatus.Accepted)
                        {
                            <p class="mb-2 small text-muted"><i class="bi bi-broadcast"></i> Live tracking status is shown above the map once your driver starts the trip.</p>
                        }
                        @if (myRequest.Status == UniConnect.Models.RideRequestStatus.Pending
                       || myRequest.Status == UniConnect.Models.RideRequestStatus.Accepted)
                        {
                            <form asp-action="CancelRequest" asp-route-requestId="@myRequest.Id" method="post"
                                  data-confirm="Cancel your seat request?">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-x-circle me-1"></i>Cancel Request</button>
                            </form>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* ── Driver: request management ── *@
    @if (isDriver)
    {
        var requests = Model.Requests
        .Where(r => r.Status != UniConnect.Models.RideRequestStatus.Cancelled)
        .OrderBy(r => r.RequestedAt).ToList();
        var pendingCount = requests.Count(r => r.Status == UniConnect.Models.RideRequestStatus.Pending);
        <div class="col-lg-6">
            <div class="rd-panel">
                <h2 class="rd-panel-title">
                    <i class="bi bi-inbox"></i> Ride Requests
                    @if (pendingCount > 0)
                    {
                        <span class="rd-pending-badge">@pendingCount pending</span>
                    }
                </h2>
                @if (!requests.Any())
                {
                    <div class="rd-empty-req"><i class="bi bi-inbox"></i> No requests yet.</div>
                }
                else
                {
                    <ul class="rd-req-list">
                        @foreach (var req in requests)
                        {
                            <li class="rd-req">
                                <div class="rd-req-info">
                                    <strong>@req.Passenger?.FullName</strong>
                                    <small><i class="bi bi-geo-alt"></i> @req.PickupLocation</small>
                                </div>
                                <div class="rd-req-action">
                                    @if (req.Status == UniConnect.Models.RideRequestStatus.Pending)
                                    {
                                        <form asp-action="AcceptRequest" asp-route-requestId="@req.Id" method="post" class="d-inline" data-loading>
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-success btn-sm" title="Accept"><i class="bi bi-check-lg"></i></button>
                                        </form>
                                        <form asp-action="RejectRequest" asp-route-requestId="@req.Id" method="post" class="d-inline" data-loading>
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-outline-danger btn-sm" title="Reject"><i class="bi bi-x-lg"></i></button>
                                        </form>
                                    }
                                    else
                                    {
                                        var c = req.Status switch
                                        {
                                            UniConnect.Models.RideRequestStatus.Accepted => "uc-pill-green",
                                            UniConnect.Models.RideRequestStatus.Rejected => "uc-pill-red",
                                            _ => "uc-pill-grey"
                                        };
                                        <span class="uc-pill @c">@req.Status</span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/pages/ride-details.js" asp-append-version="true"></script>
    <script src="~/js/pages/ride-tracking.js" asp-append-version="true"></script>
}
