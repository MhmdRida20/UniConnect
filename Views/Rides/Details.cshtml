@model UniConnect.Models.Ride
@{
    ViewData["Title"] = "Ride Details";
    var isDriver = (bool)ViewBag.IsDriver;
    var myRequest = ViewBag.MyRequest as UniConnect.Models.RideRequest;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-start">
    <div>
        <h2>@Model.DepartureLocation → @Model.Destination</h2>
        <p class="text-muted">
            Driver: @Model.Driver?.FullName ·
            Departs @Model.DepartureTime.ToString("dddd, MMM dd · HH:mm")
        </p>
    </div>
    <span class="badge bg-secondary fs-6 align-self-center">@Model.Status</span>
</div>

<hr />

@* ---------- MAP ---------- *@
<div id="rideMap" style="height: 350px; border-radius: 8px; margin-bottom: 1rem;
     border: 1px solid #ddd;"></div>

<div class="row">
    <div class="col-md-6">
        <h5>Ride Info</h5>
        <p><strong>Vehicle:</strong> @Model.VehicleType</p>
        <p><strong>Seats:</strong> @Model.AvailableSeats available of @Model.TotalSeats</p>
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <p><strong>Notes:</strong> @Model.Notes</p>
        }

        @* ---------- DRIVER CONTROLS ---------- *@
        @if (isDriver)
        {
            <div class="mt-3">
                @if (Model.Status == UniConnect.Models.RideStatus.Active
               || Model.Status == UniConnect.Models.RideStatus.Full)
                {
                    <form asp-action="CompleteRide" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-success btn-sm">Mark Completed</button>
                    </form>
                    <form asp-action="CancelRide" asp-route-id="@Model.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Cancel this ride? All passengers will be notified.');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-danger btn-sm">Cancel Ride</button>
                    </form>
                }
            </div>
        }
        else
        {
            @* ---------- PASSENGER CONTROLS ---------- *@
            @if (myRequest == null)
            {
                @if (Model.Status == UniConnect.Models.RideStatus.Active && Model.AvailableSeats > 0)
                {
                    <div class="card mt-3">
                        <div class="card-body">
                            <h6>Request a seat</h6>
                            <form asp-action="RequestRide" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-2">
                                    <label class="form-label">Your pickup location</label>
                                    <input type="text" name="pickupLocation" class="form-control"
                                           maxlength="150" required placeholder="Where should the driver pick you up?" />
                                </div>
                                <button class="btn btn-primary btn-sm">Send Request</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning mt-3">This ride is not accepting requests.</div>
                }
            }
            else
            {
                <div class="alert alert-info mt-3">
                    Your request status:
                    <strong>@myRequest.Status</strong>
                    (pickup: @myRequest.PickupLocation)
                    @if (myRequest.Status == UniConnect.Models.RideRequestStatus.Pending
                   || myRequest.Status == UniConnect.Models.RideRequestStatus.Accepted)
                    {
                        <form asp-action="CancelRequest" asp-route-requestId="@myRequest.Id"
                              method="post" class="d-inline ms-2">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger btn-sm">Cancel Request</button>
                        </form>
                    }
                </div>
            }
        }
    </div>

    @* ---------- REQUEST LIST (driver sees & manages; UC-05) ---------- *@
    @if (isDriver)
    {
        <div class="col-md-6">
            <h5>Ride Requests</h5>
            @{
                var requests = Model.Requests
                .Where(r => r.Status != UniConnect.Models.RideRequestStatus.Cancelled)
                .OrderBy(r => r.RequestedAt).ToList();
            }
            @if (!requests.Any())
            {
                <p class="text-muted">No requests yet.</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var req in requests)
                    {
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@req.Passenger?.FullName</strong><br />
                                    <small class="text-muted">Pickup: @req.PickupLocation</small>
                                </div>
                                <div class="text-end">
                                    @if (req.Status == UniConnect.Models.RideRequestStatus.Pending)
                                    {
                                        <form asp-action="AcceptRequest" asp-route-requestId="@req.Id"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-success btn-sm">Accept</button>
                                        </form>
                                        <form asp-action="RejectRequest" asp-route-requestId="@req.Id"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-outline-danger btn-sm">Reject</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@req.Status</span>
                                    }
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    }
</div>

<p class="mt-3">
    <a asp-action="Index" class="btn btn-link">← Back to rides</a>
</p>

@section Scripts {
    <!-- Leaflet CSS + JS from CDN (free, no API key) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Build the list of points to plot, from server-side data.
        const points = [];

        @if (Model.DepartureLat.HasValue && Model.DepartureLng.HasValue)
        {
            <text>
                points.push({
                    lat: @Model.DepartureLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    lng: @Model.DepartureLng.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    label: 'Departure: @Html.Raw(Json.Serialize(Model.DepartureLocation))'.replace(/^"|"$/g,''),
                    color: 'green'
                });
            </text>
        }

        @if (Model.DestinationLat.HasValue && Model.DestinationLng.HasValue)
        {
            <text>
                points.push({
                    lat: @Model.DestinationLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    lng: @Model.DestinationLng.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    label: 'Destination: @Html.Raw(Json.Serialize(Model.Destination))'.replace(/^"|"$/g,''),
                    color: 'red'
                });
            </text>
        }

        @* Accepted pickups — only the driver needs to see all of them *@
        @if (isDriver)
        {
            foreach (var req in Model.Requests.Where(r =>
                r.Status == UniConnect.Models.RideRequestStatus.Accepted
                && r.PickupLat.HasValue && r.PickupLng.HasValue))
            {
                <text>
                        points.push({
                            lat: @req.PickupLat!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            lng: @req.PickupLng!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            label: 'Pickup: @Html.Raw(Json.Serialize(req.Passenger != null ? req.Passenger.FullName : "Passenger"))'.replace(/^"|"$/g,''),
                            color: 'blue'
                        });
                </text>
            }
        }

        // Initialize the map
        const map = L.map('rideMap');
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);

        if (points.length > 0) {
            const markers = [];
            points.forEach(p => {
                const icon = L.icon({
                    iconUrl: `https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-${p.color}.png`,
                    shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
                    iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
                });
                const m = L.marker([p.lat, p.lng], { icon }).addTo(map).bindPopup(p.label);
                markers.push(m);
            });
            // Fit the map to show all points
            const group = L.featureGroup(markers);
            map.fitBounds(group.getBounds().pad(0.3));
        } else {
            // No coordinates available — show a default view (Beirut) with a note
            map.setView([33.8938, 35.5018], 12);
            L.popup()
                .setLatLng([33.8938, 35.5018])
                .setContent('Map location not available for this ride yet.')
                .openOn(map);
        }
    </script>
}
