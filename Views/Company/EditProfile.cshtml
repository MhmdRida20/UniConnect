@model UniConnect.Models.Company
@{
    ViewData["Title"] = "Edit Company Profile";
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/form-page.css" asp-append-version="true" />
}

<a asp-action="Index" class="form-back mb-3 d-inline-block"><i class="bi bi-arrow-left"></i> Back</a>

<div class="uc-form-card" style="max-width:600px;">
    <h3 class="mb-3">Company Profile</h3>
    <form asp-action="EditProfile" method="post" enctype="multipart/form-data" data-loading>
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Company Name</label>
            <input type="text" name="companyName" class="form-control" value="@Model.CompanyName" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control" rows="3">@Model.Description</textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Contact Email</label>
            <input type="email" name="contactEmail" class="form-control" value="@Model.ContactEmail" required />
        </div>
        <div class="mb-3">
            @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
            {
                <img src="@Model.LogoPath" alt="" style="width:60px;height:60px;object-fit:cover;border-radius:8px;" class="mb-2 d-block" />
            }
            <label class="form-label">Logo <span class="text-muted fw-normal">(optional, max 2 MB)</span></label>
            <input type="file" name="logo" class="form-control" accept=".png,.jpg,.jpeg" />
        </div>

        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
    </form>
</div>
