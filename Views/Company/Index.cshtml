@model IEnumerable<UniConnect.Models.Internship>
@{
    ViewData["Title"] = "My Internships";
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
    var company = ViewBag.Company as UniConnect.Models.Company;
    var internships = Model.ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/internships.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/staff-tickets.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h2 class="mb-0">@company?.CompanyName</h2>
        <p class="text-muted mb-0">@company?.ContactEmail</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="EditProfile" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil-square"></i> Edit Profile</a>
        <a asp-action="PostInternship" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Post Internship</a>
    </div>
</div>

@if (!internships.Any())
{
    <div class="uc-empty">
        <span class="uc-empty-icon"><i class="bi bi-briefcase"></i></span>
        <h5>No internships posted yet</h5>
        <p>Post your first opportunity to start receiving applications.</p>
        <a class="btn btn-primary mt-2" asp-action="PostInternship">Post Internship</a>
    </div>
}
else
{
    @foreach (var i in internships)
    {
        var applicationCount = i.Applications.Count;
        var pendingCount = i.Applications.Count(a => a.Status is UniConnect.Models.InternshipApplicationStatus.Submitted
                                                              or UniConnect.Models.InternshipApplicationStatus.UnderReview
                                                              or UniConnect.Models.InternshipApplicationStatus.Shortlisted);
        <div class="internship-post-card">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <strong>@i.Title</strong>
                    <span class="uc-pill uc-pill-grey ms-2">For @i.ExternalEmployerName</span>
                    @if (i.PostingMode == UniConnect.Models.InternshipPostingMode.ListingOnly)
                    {
                        <span class="uc-pill uc-pill-grey ms-2"><i class="bi bi-box-arrow-up-right"></i> Listing only</span>
                    }
                    else if (i.ShortlistSentAt.HasValue)
                    {
                        <span class="uc-pill uc-pill-green ms-2"><i class="bi bi-check-circle"></i> Shortlist sent</span>
                    }
                    @if (!i.IsActive)
                    {
                        <span class="uc-pill uc-pill-grey ms-2">Deactivated</span>
                    }
                    <p class="text-muted small mb-0">
                        <i class="bi bi-geo-alt"></i>@i.Location ·
                        <i class="bi bi-calendar-x"></i>Deadline @i.ApplicationDeadline.ToString("MMM dd, yyyy") ·
                        <i class="bi bi-people"></i>@applicationCount application@(applicationCount == 1 ? "" : "s") (@pendingCount pending)
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Applications" asp-route-internshipId="@i.Id" class="btn btn-outline-secondary btn-sm">Applications</a>
                    <a asp-action="EditInternship" asp-route-id="@i.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                    <form asp-action="ToggleActive" asp-route-id="@i.Id" method="post"
                          data-confirm="@(i.IsActive ? "Deactivate this internship? Pending applicants will be notified." : "Reactivate this internship?")">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-danger btn-sm">@(i.IsActive ? "Deactivate" : "Reactivate")</button>
                    </form>
                </div>
            </div>
        </div>
    }
}
