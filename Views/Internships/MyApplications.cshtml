@model IEnumerable<UniConnect.Models.InternshipApplication>
@{
    ViewData["Title"] = "My Applications";
    var applications = Model.ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/internships.css" asp-append-version="true" />
}

<div class="uc-hero" style="padding:1.5rem 0;">
    <div class="uc-hero-inner d-flex justify-content-between align-items-end flex-wrap gap-2">
        <div>
            <p class="uc-eyebrow"><i class="bi bi-send"></i>Internships</p>
            <h1 class="uc-hero-title mb-0" style="font-size:1.6rem;">My Applications</h1>
        </div>
        <a class="btn btn-light home-cta-light fw-bold" asp-action="Index"><i class="bi bi-search me-1"></i>Browse Internships</a>
    </div>
</div>

<div class="container" style="padding-top:1.25rem;">
    @if (!applications.Any())
    {
        <div class="uc-empty">
            <span class="uc-empty-icon"><i class="bi bi-send"></i></span>
            <h5>No applications yet</h5>
            <p>Browse internships and apply to get started.</p>
            <a class="btn btn-primary mt-2" asp-action="Index">Browse Internships</a>
        </div>
    }
    else
    {
        @foreach (var a in applications)
        {
            var canWithdraw = a.Status is UniConnect.Models.InternshipApplicationStatus.Submitted
                                        or UniConnect.Models.InternshipApplicationStatus.UnderReview
                                        or UniConnect.Models.InternshipApplicationStatus.Shortlisted;
            <div class="uc-form-card mb-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <strong>@a.Internship?.Title</strong>
                    <p class="text-muted small mb-0"><i class="bi bi-building"></i> @a.Internship?.Company?.CompanyName · Applied @a.AppliedAt.ToString("MMM dd, yyyy")</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (a.MatchingScore.HasValue)
                    {
                        <span class="match-badge match-@(a.MatchingScore >= 70 ? "high" : a.MatchingScore >= 40 ? "mid" : "low")">@a.MatchingScore%</span>
                    }
                    <span class="uc-pill status-@a.Status.ToString().ToLower()">@a.Status</span>
                    @if (canWithdraw)
                    {
                        <form asp-action="Withdraw" method="post" data-confirm="Withdraw this application?">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@a.Id" />
                            <button class="btn btn-outline-danger btn-sm">Withdraw</button>
                        </form>
                    }
                </div>
            </div>
        }
    }
</div>
