@model UniConnect.Models.StudyGroup
@{
    ViewData["Title"] = Model.GroupName;
    var isMember = (bool)ViewBag.IsMember;
    var isCreator = (bool)ViewBag.IsCreator;
    var approved = (int)ViewBag.ApprovedCount;
    var currentId = ViewBag.CurrentUserId as string;
    var isFull = Model.Status == UniConnect.Models.StudyGroupStatus.Full;
    var isInactive = Model.Status == UniConnect.Models.StudyGroupStatus.Inactive;
    var myStatus = ViewBag.MyMembershipStatus as UniConnect.Models.MembershipStatus?;
    var isPending = myStatus == UniConnect.Models.MembershipStatus.Pending;
    var currentName = Model.Members.FirstOrDefault(m => m.UserId == currentId)?.User?.FullName ?? "";
    var pendingRequests = Model.Members.Where(m => m.Status == UniConnect.Models.MembershipStatus.Pending)
                                        .OrderBy(m => m.JoinedAt).ToList();

    string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][..1].ToUpper()
            : (parts[0][..1] + parts[^1][..1]).ToUpper();
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/study-group-details.css" asp-append-version="true" />
}



<a asp-action="Index" class="form-back"><i class="bi bi-arrow-left"></i> Back to study groups</a>

@* ── Group header ── *@
<div class="sgd-header">
    <div class="sgd-header-main">
        <span class="uc-pill uc-pill-green mb-2"><span class="dot"></span>@Model.Course?.CourseCode — @Model.Course?.CourseName</span>
        <h1>@Model.GroupName</h1>
        <p class="sgd-header-meta">
            <span><i class="bi bi-person-circle"></i> Created by @Model.Creator?.FullName</span>
            <span><i class="bi bi-calendar3"></i> @Model.CreatedAt.ToString("MMM dd, yyyy")</span>
            @if (!string.IsNullOrWhiteSpace(Model.Course?.InstructorName))
            {
                <span><i class="bi bi-mortarboard"></i> @Model.Course?.InstructorName</span>
            }
        </p>
    </div>
    <div class="sgd-header-action">
        @if (!isMember && !isPending)
        {
            <form asp-action="Join" asp-route-id="@Model.Id" method="post" data-loading>
                @Html.AntiForgeryToken()
                <button class="btn btn-primary btn-lg" @(isFull ? "disabled" : "") data-loading-text="Sending request…">
                    <i class="bi bi-plus-circle me-1"></i>@(isFull ? "Group Full" : "Request to Join")
                </button>
            </form>
        }
        else if (isPending)
        {
            <div class="d-flex flex-column align-items-end gap-2">
                <span class="uc-pill uc-pill-amber"><i class="bi bi-hourglass-split"></i>Request pending approval</span>
                <form asp-action="Leave" asp-route-id="@Model.Id" method="post"
                      data-confirm="Withdraw your request to join this group?">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Withdraw request</button>
                </form>
            </div>
        }
        else if (!isCreator)
        {
            <form asp-action="Leave" asp-route-id="@Model.Id" method="post"
                  data-confirm="Leave this study group?">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger"><i class="bi bi-box-arrow-left me-1"></i>Leave Group</button>
            </form>
        }
        else
        {
            <span class="uc-pill uc-pill-green"><i class="bi bi-star-fill"></i>You created this group</span>
        }
    </div>
</div>

@if (isInactive)
{
    <div class="alert alert-secondary uc-flash">
        <i class="bi bi-moon-stars"></i> This group has been marked <strong>inactive</strong> due to no recent activity.
        @(isMember ? "Send a message or approve a member to bring it back." : "")
    </div>
}

<div class="row g-4 sgd-body">
    @* ── Left: info + chat ── *@
    <div class="col-lg-8">
        @* Stat tiles *@
        <div class="sgd-stats">
            <div class="sgd-stat">
                <span class="sgd-stat-ico" style="background:#dcfce7;color:#15803d;"><i class="bi bi-people-fill"></i></span>
                <div><span class="sgd-stat-val">@approved / @Model.MaxMembers</span><span class="sgd-stat-lbl">Members</span></div>
            </div>
            <div class="sgd-stat">
                <span class="sgd-stat-ico" style="background:#ccfbf1;color:#0f766e;"><i class="bi bi-geo-alt-fill"></i></span>
                <div><span class="sgd-stat-val">@(string.IsNullOrWhiteSpace(Model.MeetingLocation) ? "Not set" : Model.MeetingLocation)</span><span class="sgd-stat-lbl">Meeting spot</span></div>
            </div>
            <div class="sgd-stat">
                <span class="sgd-stat-ico" style="background:#fef3c7;color:#92400e;"><i class="bi bi-flag-fill"></i></span>
                <div><span class="sgd-stat-val">@Model.Status</span><span class="sgd-stat-lbl">Status</span></div>
            </div>
        </div>

        @* About *@
        <div class="sgd-panel">
            <h2 class="sgd-panel-title"><i class="bi bi-info-circle"></i> About this group</h2>
            <p class="sgd-about">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
            <p class="sgd-meta-line"><strong>Minimum to run:</strong> @Model.MinMembers members</p>
        </div>

        @* Chat *@
        <div class="sgd-panel sgd-chat-panel"
             data-group-id="@Model.Id"
             data-current-name="@currentName"
             data-current-user-id="@currentId"
             data-is-creator="@(isCreator ? "true" : "false")"
             data-post-url="@Url.Action("PostMessage", "StudyGroups", new { id = Model.Id })">
            <h2 class="sgd-panel-title">
                <i class="bi bi-chat-dots"></i> Group Chat
                <span class="sgd-live" id="liveStatus"><span class="sgd-live-dot"></span>connecting…</span>
            </h2>

            <div id="messagesList" class="sgd-messages">
                @if (!Model.Messages.Any())
                {
                    <div id="noMessagesPlaceholder" class="sgd-chat-empty">
                        <i class="bi bi-chat-square-text"></i>
                        <span>No messages yet. @(isMember ? "Say hello!" : "Join the group to start chatting.")</span>
                    </div>
                }
                @foreach (var msg in Model.Messages)
                {
                    var mine = msg.SenderId == currentId;
                    <div class="sgd-msg @(mine ? "is-mine" : "")">
                        <span class="sgd-avatar">@Initials(msg.Sender?.FullName)</span>
                        <div class="sgd-bubble">
                            <div class="sgd-bubble-head">
                                <strong>@(mine ? "You" : msg.Sender?.FullName)</strong>
                                <small>@msg.SentAt.ToString("MMM dd, HH:mm")</small>
                            </div>
                            <div class="sgd-bubble-text">@msg.Content</div>
                        </div>
                    </div>
                }
            </div>

            @if (isMember)
            {
                <form id="messageForm" class="sgd-composer">
                    @Html.AntiForgeryToken()
                    <input type="text" id="messageInput" class="form-control" maxlength="1000"
                           placeholder="Write a message…" required autocomplete="off" />
                    <button type="submit" class="btn btn-primary" aria-label="Send message">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            }
            else
            {
                <div class="sgd-join-hint">
                    <i class="bi bi-lock"></i> Join this group to take part in the chat.
                </div>
            }
        </div>
    </div>

    @* ── Right: members ── *@
    <div class="col-lg-4">
        @if (isCreator && pendingRequests.Any())
        {
            <div class="sgd-panel sgd-pending">
                <h2 class="sgd-panel-title">
                    <i class="bi bi-person-plus"></i> Join Requests <span class="sgd-count sgd-count-amber">@pendingRequests.Count</span>
                </h2>
                <ul class="sgd-member-list" id="pendingList">
                    @foreach (var m in pendingRequests)
                    {
                        <li class="sgd-member">
                            <span class="sgd-avatar">@Initials(m.User?.FullName)</span>
                            <div class="sgd-member-info">
                                <strong>@m.User?.FullName</strong>
                                <small>Requested @m.JoinedAt.ToString("MMM dd, HH:mm")</small>
                            </div>
                            <div class="sgd-pending-actions">
                                <form asp-action="ApproveMember" asp-route-memberId="@m.Id" method="post" class="d-inline" data-loading>
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-success btn-sm" title="Approve"><i class="bi bi-check-lg"></i></button>
                                </form>
                                <form asp-action="RejectMember" asp-route-memberId="@m.Id" method="post" class="d-inline"
                                      data-confirm="Reject @(m.User?.FullName ?? "this student")'s request?">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-danger btn-sm" title="Reject"><i class="bi bi-x-lg"></i></button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        <div class="sgd-panel sgd-members">
            <h2 class="sgd-panel-title"><i class="bi bi-people"></i> Members <span class="sgd-count">@approved</span></h2>
            <ul class="sgd-member-list">
                @foreach (var m in Model.Members.Where(x => x.Status == UniConnect.Models.MembershipStatus.Approved))
                {
                    var isOwn = m.UserId == currentId;
                    <li class="sgd-member @(isOwn ? "is-own" : "")">
                        <span class="sgd-avatar">@Initials(m.User?.FullName)</span>
                        <div class="sgd-member-info">
                            <strong>@m.User?.FullName @(isOwn ? "(You)" : "")</strong>
                            <small>Joined @m.JoinedAt.ToString("MMM dd")</small>
                        </div>
                        @if (m.UserId == Model.CreatorId)
                        {
                            <span class="uc-pill uc-pill-green ms-auto"><i class="bi bi-star-fill"></i>Creator</span>
                        }
                        else if (isCreator)
                        {
                            <div class="sgd-member-actions ms-auto">
                                <form asp-action="TransferLeadership" asp-route-memberId="@m.Id" method="post" class="d-inline"
                                      data-confirm="Make @(m.User?.FullName ?? "this member") the new group leader? You'll no longer be the creator.">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-secondary btn-sm" title="Make group leader"><i class="bi bi-star"></i></button>
                                </form>
                                <form asp-action="RemoveMember" asp-route-memberId="@m.Id" method="post" class="d-inline"
                                      data-confirm="Remove @(m.User?.FullName ?? "this member") from the group?">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-danger btn-sm" title="Remove member"><i class="bi bi-person-dash"></i></button>
                                </form>
                            </div>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/pages/study-group-details.js" asp-append-version="true"></script>
}
