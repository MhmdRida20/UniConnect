@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/static-page.css" asp-append-version="true" />
}

<div class="error-page">
    <span class="error-ico"><i class="bi bi-exclamation-octagon-fill"></i></span>
    <h1>Something went wrong</h1>
    <p>An unexpected error occurred while processing your request. Please try again, or head back home.</p>

    @if (Model.ShowRequestId)
    {
        <p class="error-reqid">Request ID: <code>@Model.RequestId</code></p>
    }

    <div class="error-actions">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary"><i class="bi bi-house-door me-1"></i>Back to home</a>
        <button onclick="history.back()" class="btn btn-outline-primary" type="button"><i class="bi bi-arrow-left me-1"></i>Go back</button>
    </div>

    <details class="error-dev">
        <summary>Developer information</summary>
        <p>
            Swapping to the <strong>Development</strong> environment displays more detailed information
            about the error. The Development environment shouldn't be enabled for deployed applications,
            as it can expose sensitive details from exceptions to end users. Enable it locally by setting
            <code>ASPNETCORE_ENVIRONMENT</code> to <strong>Development</strong> and restarting the app.
        </p>
    </details>
</div>
