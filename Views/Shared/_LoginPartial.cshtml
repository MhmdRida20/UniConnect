@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using UniConnect.Models
@using UniConnect.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext Db

<ul class="navbar-nav uc-account-nav align-items-xl-center gap-xl-1">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var currentUserId = currentUser?.Id;
        var unreadCount = await Db.Notifications.CountAsync(n => n.UserId == currentUserId && !n.IsRead);
        var initial = string.IsNullOrEmpty(currentUser?.FullName) ? "?" : currentUser.FullName.Substring(0, 1).ToUpperInvariant();

        <li class="nav-item">
            <a class="nav-link uc-bell d-inline-flex align-items-center position-relative" asp-controller="Notifications" asp-action="Index" title="Notifications" id="notificationBellLink">
                <svg class="hgi"><use href="#i-bell"></use></svg>
                <span id="notificationBellCount" class="uc-bell-badge" style="@(unreadCount == 0 ? "display:none;" : "")">@unreadCount</span>
            </a>
        </li>
        <li class="nav-item dropdown uc-account-item">
            <a class="nav-link uc-account-toggle d-inline-flex align-items-center" href="#" role="button"
               data-bs-toggle="dropdown" aria-expanded="false">
                <span class="uc-account-avatar">@initial</span>
                <span class="uc-account-name d-none d-xl-inline">@currentUser?.FullName</span>
                <svg class="hgi hgi-sm uc-account-caret"><use href="#i-arrow-right"></use></svg>
            </a>
            <div class="dropdown-menu dropdown-menu-end uc-account-menu">
                <div class="uc-account-menu-head">
                    <span class="uc-account-avatar uc-account-avatar-lg">@initial</span>
                    <div>
                        <strong>@currentUser?.FullName</strong>
                        <small>@currentUser?.Email</small>
                    </div>
                </div>
                <div class="uc-account-menu-body">
                    <a class="uc-account-menu-link" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <svg class="hgi hgi-sm"><use href="#i-user-circle"></use></svg>Manage account
                    </a>
                    <a class="uc-account-menu-link" asp-area="Identity" asp-page="/Account/Manage/Index" asp-fragment="password">
                        <svg class="hgi hgi-sm"><use href="#i-settings"></use></svg>Security settings
                    </a>
                </div>
                <form class="uc-account-menu-foot" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="uc-account-menu-link uc-account-logout">
                        <svg class="hgi hgi-sm"><use href="#i-logout"></use></svg>Log out
                    </button>
                </form>
            </div>
        </li>
        <li class="d-none" data-current-user-id="@currentUserId" id="notificationUserConfig"></li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link uc-nav-login" asp-area="Identity" asp-page="/Account/Login">
                <svg class="hgi hgi-sm"><use href="#i-login"></use></svg>Log in
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary btn-sm uc-nav-signup" asp-area="Identity" asp-page="/Account/Register">
                <svg class="hgi hgi-sm"><use href="#i-user-add"></use></svg>Sign up
            </a>
        </li>
    }
</ul>
