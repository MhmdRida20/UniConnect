@using Microsoft.AspNetCore.Identity
@using UniConnect.Models
@using UniConnect.Services
@using Microsoft.EntityFrameworkCore
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IServiceCatalogService ServiceCatalog
@inject UniConnect.Data.ApplicationDbContext Db
@{
    var routeData = ViewContext.RouteData.Values;
    var currentController = routeData["controller"]?.ToString();
    var currentAction = routeData["action"]?.ToString();
    string NavActive(string controller, string? action = null) =>
        (currentController == controller && (action == null || currentAction == action)) ? "active" : "";

    // Only show nav items for services the current user's university has
    // actually enabled (Front Design doc: nav is filtered by "enabled
    // services for the university"). Anonymous visitors still see everything,
    // since there's no university context to filter by until they log in.
    var enabledServices = new List<string>();
    // FR-17: "flag reduced functionality" — if the last sync with this
    // student's university genuinely failed, some course/enrollment/major
    // data shown around the site may be stale until the next successful
    // sync. This is informational, not an error the student caused.
    string? syncBannerMessage = null;
    if (SignInManager.IsSignedIn(User))
    {
        var navUser = await UserManager.GetUserAsync(User);
        if (navUser is not null)
        {
            enabledServices = await ServiceCatalog.GetEnabledServiceCodesAsync(navUser.UniversityCode);

            var navUniversity = await Db.Universities.AsNoTracking()
                .FirstOrDefaultAsync(u => u.Code == navUser.UniversityCode);
            if (navUniversity?.LastSyncStatus == "Failed")
            {
                syncBannerMessage = "We're having trouble syncing with your university's system right now — " +
                    "course, enrollment, and major information shown here may be temporarily out of date.";
            }
        }
    }
    bool ShowNav(string serviceCode) => !SignInManager.IsSignedIn(User) || enabledServices.Contains(serviceCode);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#16a34a" />
    <title>@ViewData["Title"] - UniConnect</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniConnect.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <partial name="_Icons" />
    <header>
        <nav class="navbar navbar-expand-xl uc-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand uc-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="uc-brand-mark"><svg class="hgi"><use href="#i-graduation"></use></svg></span>
                    <span>Uni<b>Connect</b></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <svg class="hgi uc-toggler-open"><use href="#i-menu"></use></svg>
                    <svg class="hgi uc-toggler-close"><use href="#i-close"></use></svg>
                </button>
                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-xl-0">
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index">
                                <svg class="hgi hgi-sm"><use href="#i-home"></use></svg>Home
                            </a>
                        </li>
                        @if (ShowNav(ServiceCodes.StudyGroups))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("StudyGroups", "Index")" asp-controller="StudyGroups" asp-action="Index">
                                    <svg class="hgi hgi-sm"><use href="#i-users"></use></svg>Study Groups
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("StudyGroups", "MyCourses")" asp-controller="StudyGroups" asp-action="MyCourses">
                                    <svg class="hgi hgi-sm"><use href="#i-book"></use></svg>My Courses
                                </a>
                            </li>
                        }
                        @if (ShowNav(ServiceCodes.RideSharing))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Rides")" asp-controller="Rides" asp-action="Index">
                                    <svg class="hgi hgi-sm"><use href="#i-car"></use></svg>Rides
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Vehicles")" asp-controller="Vehicles" asp-action="Index">
                                    <svg class="hgi hgi-sm"><use href="#i-car"></use></svg>My Vehicles
                                </a>
                            </li>
                        }
                        @if (ShowNav(ServiceCodes.Tickets))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Tickets")" asp-controller="Tickets" asp-action="Index">
                                    <svg class="hgi hgi-sm"><use href="#i-ticket"></use></svg>My Tickets
                                </a>
                            </li>
                        }
                        @if (ShowNav(ServiceCodes.Clubs))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Clubs")" asp-controller="Clubs" asp-action="Index">
                                    <svg class="hgi hgi-sm"><use href="#i-user-multiple"></use></svg>Clubs
                                </a>
                            </li>
                        }
                        @if (ShowNav(ServiceCodes.Attendance) && User.IsInRole("Instructor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("InstructorAttendance")" asp-controller="InstructorAttendance" asp-action="Index">
                                    <svg class="hgi hgi-sm"><use href="#i-qr"></use></svg>My Sessions
                                </a>
                            </li>
                        }
                        @if (ShowNav(ServiceCodes.Attendance) && !User.IsInRole("Instructor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Attendance")" asp-controller="Attendance" asp-action="MyAttendance">
                                    <svg class="hgi hgi-sm"><use href="#i-qr"></use></svg>My Attendance
                                </a>
                            </li>
                        }
                        @if (ShowNav(ServiceCodes.Internships) && !User.IsInRole("Company") && !User.IsInRole("Instructor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Internships")" asp-controller="Internships" asp-action="Index">
                                    <svg class="hgi hgi-sm"><use href="#i-briefcase"></use></svg>Internships
                                </a>
                            </li>
                        }
                    </ul>
                    <span class="uc-navbar-divider d-none d-xl-block" aria-hidden="true"></span>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    @if (syncBannerMessage is not null)
    {
        <div class="uc-sync-banner">
            <div class="container d-flex align-items-center gap-2">
                <svg class="hgi hgi-sm"><use href="#i-info"></use></svg>
                <span>@syncBannerMessage</span>
            </div>
        </div>
    }

    <main role="main">
        <div class="container">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success uc-flash">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger uc-flash">@TempData["Error"]</div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="uc-footer">
        <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
            <span class="d-inline-flex align-items-center gap-2">
                <svg class="hgi hgi-sm" style="color: var(--uc-primary);"><use href="#i-graduation"></use></svg>
                &copy; 2026 UniConnect — Connect. Study. Commute.
            </span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/global-notifications.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
