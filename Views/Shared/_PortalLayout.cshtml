@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using UniConnect.Models
@using UniConnect.Data
@inject UserManager<ApplicationUser> PortalUserManager
@inject ApplicationDbContext PortalDb
@{
    var routeData = ViewContext.RouteData.Values;
    var currentController = routeData["controller"]?.ToString();
    string NavActive(string controller) => currentController == controller ? "active" : "";

    var portalUser = await PortalUserManager.GetUserAsync(User);
    var unreadCount = portalUser is null ? 0 : await PortalDb.Notifications.CountAsync(n => n.UserId == portalUser.Id && !n.IsRead);
    var isAdmin = User.IsInRole("Admin");

    // Real per-university context for the topbar pill — an Admin manages
    // every university (Super Admin scope), so there's no single "current"
    // one to show; everyone else (staff/company) belongs to exactly one.
    string? universityName = null;
    string? syncBannerMessage = null;
    if (!isAdmin && portalUser is not null)
    {
        var portalUniversity = await PortalDb.Universities.FindAsync(portalUser.UniversityCode);
        universityName = portalUniversity?.Name;

        // FR-17: same reduced-functionality notice as the student layout —
        // staff/instructors rely on the same synced data (rosters, course
        // lists) and are just as affected by a failed sync.
        if (portalUniversity?.LastSyncStatus == "Failed")
        {
            syncBannerMessage = "We're having trouble syncing with the university's system right now — " +
                "some course, roster, or enrollment information may be temporarily out of date.";
        }
    }

    var initial = string.IsNullOrEmpty(portalUser?.FullName) ? "?" : portalUser.FullName.Substring(0, 1).ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#16a34a" />
    <title>@ViewData["Title"] - UniConnect Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portal-layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="portal-body">
    <partial name="_Icons" />

    <div class="portal-shell">
        <span class="portal-backdrop" data-portal-backdrop aria-hidden="true"></span>

        <aside class="portal-sidebar" data-portal-sidebar>
            <a class="portal-brand" asp-controller="Home" asp-action="Index">
                <span class="uc-brand-mark"><svg class="hgi"><use href="#i-graduation"></use></svg></span>
                <span>Uni<b>Connect</b> <small>Portal</small></span>
            </a>

            <nav class="portal-nav">
                @if (User.IsInRole("DepartmentStaff"))
                {
                    <p class="portal-nav-label">Workspace</p>
                    <a class="portal-nav-link @NavActive("StaffTickets")" asp-controller="StaffTickets" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-ticket"></use></svg>Tickets
                        <span class="portal-nav-badge" id="portalPendingBadge" hidden></span>
                    </a>
                }
                @if (User.IsInRole("Company"))
                {
                    <p class="portal-nav-label">Workspace</p>
                    <a class="portal-nav-link @NavActive("Company")" asp-controller="Company" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-briefcase"></use></svg>My Internships
                    </a>
                }
                @if (isAdmin)
                {
                    <p class="portal-nav-label">Platform Administration</p>
                    <a class="portal-nav-link @NavActive("AdminUniversities")" asp-controller="AdminUniversities" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-building"></use></svg>Universities
                    </a>
                    <a class="portal-nav-link @NavActive("AdminUsers")" asp-controller="AdminUsers" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-user-multiple"></use></svg>Users
                    </a>
                    <a class="portal-nav-link @NavActive("AdminReports")" asp-controller="AdminReports" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-chart"></use></svg>Reports
                    </a>
                    <a class="portal-nav-link @NavActive("AdminAuditLog")" asp-controller="AdminAuditLog" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-info"></use></svg>Audit Log
                    </a>
                    <a class="portal-nav-link @NavActive("AdminExternalApiSimulator")" asp-controller="AdminExternalApiSimulator" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-cloud-sync"></use></svg>External API Simulator
                    </a>
                }
                @if (User.IsInRole("UniversityAdmin"))
                {
                    <p class="portal-nav-label">University Administration</p>
                    <a class="portal-nav-link @NavActive("AdminUniversities")" asp-controller="AdminUniversities" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-building"></use></svg>My University
                    </a>
                    <a class="portal-nav-link @NavActive("AdminUsers")" asp-controller="AdminUsers" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-user-multiple"></use></svg>Users
                    </a>
                    <a class="portal-nav-link @NavActive("AdminReports")" asp-controller="AdminReports" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-chart"></use></svg>Reports
                    </a>
                    <a class="portal-nav-link @NavActive("AdminAuditLog")" asp-controller="AdminAuditLog" asp-action="Index">
                        <svg class="hgi hgi-sm"><use href="#i-info"></use></svg>Audit Log
                    </a>
                }

                <p class="portal-nav-label">General</p>
                <a class="portal-nav-link @NavActive("Notifications")" asp-controller="Notifications" asp-action="Index">
                    <svg class="hgi hgi-sm"><use href="#i-bell"></use></svg>Notifications
                    @if (unreadCount > 0)
                    {
                        <span class="portal-nav-badge">@unreadCount</span>
                    }
                </a>
            </nav>

            <div class="portal-user">
                @if (!string.IsNullOrWhiteSpace(portalUser?.ProfilePicturePath))
                {
                    <div class="portal-user-avatar" style="padding:0; overflow:hidden;">
                        <img src="@portalUser.ProfilePicturePath" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                    </div>
                }
                else
                {
                    <div class="portal-user-avatar">@initial</div>
                }
                <div class="portal-user-info">
                    <strong>@portalUser?.FullName</strong>
                    <small>
                        @if (isAdmin)
                        {
                            <text>Platform Admin</text>
                        }
                        else if (User.IsInRole("Company"))
                        {
                            <text>Company Account</text>
                        }
                        else
                        {
                            <text>@portalUser?.Department department</text>
                        }
                    </small>
                </div>
            </div>
            <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100 mb-2">
                <svg class="hgi hgi-sm me-1"><use href="#i-user-circle"></use></svg>My Profile
            </a>
            <form class="portal-logout" asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                    <svg class="hgi hgi-sm me-1"><use href="#i-logout"></use></svg>Log out
                </button>
            </form>
            <div class="d-none" data-current-user-id="@portalUser?.Id" id="notificationUserConfig"></div>
        </aside>

        <div class="portal-main-wrap">
            <header class="portal-topbar">
                <div class="portal-topbar-left">
                    <button type="button" class="portal-sidebar-toggle" data-portal-toggle aria-label="Toggle menu" aria-expanded="false">
                        <svg class="hgi"><use href="#i-menu"></use></svg>
                    </button>
                    <div class="portal-topbar-title">
                        <h1>@ViewData["Title"]</h1>
                    </div>
                </div>
                <div class="portal-topbar-right">
                    @if (isAdmin)
                    {
                        <span class="uc-pill uc-pill-green"><svg class="hgi hgi-sm"><use href="#i-shield"></use></svg>Platform-wide access</span>
                    }
                    else if (universityName is not null)
                    {
                        <span class="uc-pill uc-pill-green"><svg class="hgi hgi-sm"><use href="#i-building"></use></svg>@universityName</span>
                    }
                </div>
            </header>

            @if (syncBannerMessage is not null)
            {
                <div class="uc-sync-banner">
                    <div class="d-flex align-items-center gap-2">
                        <svg class="hgi hgi-sm"><use href="#i-info"></use></svg>
                        <span>@syncBannerMessage</span>
                    </div>
                </div>
            }

            <main class="portal-main" role="main">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success uc-flash">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger uc-flash">@TempData["Error"]</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/global-notifications.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
