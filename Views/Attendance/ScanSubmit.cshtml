@{
    ViewData["Title"] = "Submit Attendance";
    var session = ViewBag.Session as UniConnect.Models.AttendanceSession;
    var error = ViewBag.Error as string;
    var token = ViewBag.Token as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/attendance.css" asp-append-version="true" />
}

<div class="attendance-scan-page">
    <div class="attendance-scan-card">
        <span class="attendance-scan-icon"><i class="bi bi-qr-code-scan"></i></span>

        @if (error is not null || session is null)
        {
            <h1>Can't submit attendance</h1>
            <p class="text-danger">@(error ?? "This attendance link isn't valid.")</p>
            <a class="btn btn-outline-secondary mt-2" asp-action="ManualEntry">Try a different token</a>
        }
        else
        {
            <h1>@session.CourseName</h1>
            <p class="text-muted mb-3">
                @session.StartTime.ToString("MMM dd, yyyy · HH:mm") – @session.EndTime.ToString("HH:mm")
            </p>

            <div id="locationStatus" class="attendance-location-status">
                <i class="bi bi-geo-alt"></i> Getting your location…
            </div>

            <form id="attendanceSubmitForm" asp-action="Submit" method="post" data-loading>
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@token" />
                <input type="hidden" name="lat" id="latInput" />
                <input type="hidden" name="lng" id="lngInput" />
                <input type="hidden" name="deviceFingerprint" id="deviceFingerprintInput" />
                <button type="submit" class="btn btn-primary w-100 mt-2" id="confirmBtn" disabled data-loading-text="Submitting…">
                    <i class="bi bi-check-circle me-1"></i>Confirm Attendance
                </button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/attendance-submit.js" asp-append-version="true"></script>
}
